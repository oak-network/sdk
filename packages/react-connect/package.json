{
  "name": "@oaknetwork/react-connect",
  "version": "0.1.0",
  "description": "Headless React primitives for Plaid bank linking and Stripe Connect account onboarding. No UI—use your own.",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "lint": "tsc --noEmit",
    "test": "jest __tests__/unit --coverage",
    "test:unit": "jest __tests__/unit --coverage",
    "test:watch": "jest __tests__/unit --watchAll"
  },
  "dependencies": {
    "@stripe/connect-js": "^3.3.0",
    "@stripe/react-connect-js": "^3.3.0",
    "react-plaid-link": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jest": "^30.0.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.4"
  },
  "author": "oaknetwork",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oak-network/sdk",
    "directory": "packages/react-connect"
  },
  "files": [
    "dist"
  ]
}
