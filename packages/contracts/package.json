{
  "name": "@oaknetwork/contracts-sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for Oak Network smart contracts",
  "keywords": [
    "sdk",
    "oaknetwork",
    "oak",
    "typescript",
    "viem",
    "web3",
    "celo",
    "smart-contracts"
  ],
  "homepage": "https://oaknetwork.org/docs/contracts-sdk/overview",
  "bugs": {
    "url": "https://github.com/oak-network/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "import": "./dist/metrics/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "jest --testPathPatterns='__tests__/unit' --coverage",
    "test:unit": "jest --testPathPatterns='__tests__/unit' --coverage",
    "test:integration": "jest --testPathPatterns='__tests__/integration' --coverage --coverageThreshold='{}'",
    "test:watch": "jest --watchAll"
  },
  "dependencies": {
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.11",
    "dotenv": "^17.3.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  },
  "author": "oaknetwork",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oak-network/sdk",
    "directory": "packages/contracts"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}
